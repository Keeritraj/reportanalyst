import streamlit as st
import PyPDF2
import requests
import json
from fpdf import FPDF
import datetime
import tempfile
import os

# Set clean, wide page configuration
st.set_page_config(page_title="Hemo-Analyst Intelligence Engine", page_icon="🩸", layout="wide")

OLLAMA_API_URL = "http://localhost:11434/api/generate"
MODEL_NAME = "llama3.2"

# ==========================================
# CORE BACKEND UTILITIES
# ==========================================
def extract_text_from_pdf(pdf_file):
    try:
        reader = PyPDF2.PdfReader(pdf_file)
        text = ""
        for page in range(len(reader.pages)):
            text += reader.pages[page].extract_text()
        return text
    except Exception as e:
        return f"Extraction Error: {str(e)}"

def run_pre_scan(report_text):
    """Stage 1 AI Call: Rapidly scans text to identify which biomarkers are out of range."""
    prompt = f"""
    You are a medical data extraction bot. Analyze this blood test text and return a raw JSON object listing ONLY the biomarkers that are HIGH or LOW compared to their reference ranges.
    Do not write any introductory or concluding text. Return ONLY valid JSON matching this exact schema:
    {{
      "detected_issues": ["Iron", "Hemoglobin", "Vitamin D", "Magnesium", "Vitamin B12", "Cholesterol"]
    }}
    If an issue is found, add its general common name to the array. If nothing is out of bounds, return an empty array.
    
    Here is the text: {report_text}
    """
    payload = {"model": MODEL_NAME, "prompt": prompt, "stream": False, "options": {"temperature": 0.0}}
    try:
        response = requests.post(OLLAMA_API_URL, json=payload)
        response.raise_for_status()
        res_text = response.json()['response'].strip()
        # Simple extraction safety filter if model wraps output in markdown codeblocks
        if "```json" in res_text:
            res_text = res_text.split("```json")[1].split("```")[0].strip()
        elif "```" in res_text:
            res_text = res_text.split("```")[1].split("```")[0].strip()
        return json.loads(res_text).get("detected_issues", [])
    except Exception:
        # Fallback to general checklist options if JSON formatting fails locally
        return ["Iron / Hemoglobin", "Vitamin D", "Magnesium", "Vitamin B12"]

def run_final_analysis(report_text, history, user_symptoms):
    """Stage 2 AI Call: Merges report data, basic details, and dynamic symptoms into a comprehensive report."""
    prompt = f"""
    You are an expert clinical data analyst communicating directly with a patient. Analyze the blood test report text below by correlating it with the patient's demographics, their checked symptoms, and their custom-written health notes.

    === PATIENT DATA ===
    - Age: {history['age']} | Sex: {history['sex']} | Diet: {history['diet']}
    - Identified Lab Deficiencies: {history['pre_scan_issues']}
    - Confirmed Symptoms from Checklist: {", ".join(user_symptoms['checked'])}
    - Patient's Custom Written Notes: {user_symptoms['custom_text']}

    === RAW BLOOD TEST DATA ===
    {report_text}

    === STRUCTURAL INSTRUCTIONS ===
    You must format your entire response using these exact markdown headers. Keep the explanations deeply educational, clean, and engaging for a non-medical user. Avoid long paragraphs; use bullet points under headings.

    ### 🩺 CLINICAL SUMMARY & CORRELATION
    (Provide a high-level overview of the report. Explicitly connect the lab results to the symptoms they checked or wrote down.)

    ### 🚦 BIOMARKER SEVERITY BREAKDOWN (1-10 SCALE)
    (List each abnormal marker. Assign it an intuitive 1-10 severity score where 1-3 is optimal/green, 4-6 is mild deviation/amber, and 7-10 is significant deviation/red. Explain the score briefly.)

    ### 🧠 EASY-TO-UNDERSTAND MEDICAL TRANSLATION
    (Break down what these high or low markers actually do inside the body in plain, everyday language. Why do they matter?)

    ### 💊 TARGETED NUTRIENT & SUPPLEMENT PLAN
    (Provide specific, actionable dietary shifts and safe over-the-counter supplement suggestions or combinations tailored to their {history['diet']} lifestyle.)

    ### 🚨 WHEN TO CONSULT A DOCTOR (TRIAGE POINTS)
    (Give clear, specific criteria and a bulleted list of exactly what questions or red flags should prompt them to schedule an immediate doctor visit.)
    """
    payload = {"model": MODEL_NAME, "prompt": prompt, "stream": False, "options": {"temperature": 0.2}}
    try:
        response = requests.post(OLLAMA_API_URL, json=payload)
        response.raise_for_status()
        return response.json()['response']
    except Exception as e:
        return f"Error running final synthesis engine: {str(e)}"

def create_pdf_report(narrative_text, history):
    pdf = FPDF()
    pdf.add_page()
    pdf.set_font("Arial", 'B', 16)
    pdf.cell(200, 10, txt="HEMO-ANALYST: AI CLINICAL REPORT SUMMARY", ln=True, align='C')
    pdf.set_font("Arial", 'I', 10)
    pdf.cell(200, 8, txt=f"Generated on: {datetime.datetime.now().strftime('%Y-%m-%d')} | Made by Keertiraj Singh", ln=True, align='C')
    pdf.ln(10)
    
    # AI Medical Disclaimer Box
    pdf.set_fill_color(255, 230, 230)
    pdf.set_font("Arial", 'B', 10)
    pdf.cell(0, 6, txt="CRITICAL MEDICAL DISCLAIMER:", ln=True, fill=True)
    pdf.set_font("Arial", size=9)
    pdf.multi_cell(0, 5, txt="This document is an AI-assisted text analysis and serves educational purposes only. It is NOT a medical diagnosis. Please verify all findings, scores, and supplement strategies with a certified professional doctor before taking action.", fill=True)
    pdf.ln(5)
    
    # Content
    pdf.set_font("Arial", size=11)
    clean_text = narrative_text.encode('latin-1', 'replace').decode('latin-1')
    pdf.multi_cell(0, 7, txt=clean_text)
    
    temp_dir = tempfile.gettempdir()
    file_path = os.path.join(temp_dir, "HemoAnalyst_Final_Report.pdf")
    pdf.output(file_path)
    return file_path

# ==========================================
# STREAMLIT USER INTERFACE
# ==========================================
st.title("🩸 Hemo-Analyst Pro")
st.markdown("### Interactive Context-Aware Blood Report Explainer")
st.caption("Developed by Keertiraj Singh")
st.divider()

# Establish Session States to track multi-stage step inputs
if 'stage' not in st.session_state:
    st.session_state['stage'] = 1
if 'report_text' not in st.session_state:
    st.session_state['report_text'] = ""
if 'pre_scan_issues' not in st.session_state:
    st.session_state['pre_scan_issues'] = []
if 'history' not in st.session_state:
    st.session_state['history'] = {}

# Dictionary mapping common detected deficiencies to human symptoms for our checklist
symptom_dictionary = {
    "Iron": ["Chronic Fatigue", "Dizziness upon standing", "Cold hands or feet", "Pale skin", "Brittle nails"],
    "Hemoglobin": ["Shortness of breath during basic tasks", "Weakness", "Headaches", "Chest pain"],
    "Vitamin D": ["Bone pain or lower back aches", "Muscle weakness/twitches", "Mood drops or low energy", "Hair thinning"],
    "Magnesium": ["Muscle cramps or spasms", "Insomnia/Sleep trouble", "Fatigue", "Irregular heartbeats"],
    "Vitamin B12": ["Numbness or tingling in hands/feet", "Brain fog or memory lapses", "Swollen/sore tongue", "Fatigue"],
    "Cholesterol": ["Routine checkup baseline (No immediate physical symptoms)", "Family history of cardiovascular risks"]
}

# ------------------------------------------
# STAGE 1: INTAKE & FILE UPLOAD
# ------------------------------------------
if st.session_state['stage'] == 1:
    st.header("Step 1: Baseline Demographics & Report Ingestion")
    
    col_inputs, col_upload = st.columns([1, 1.2])
    with col_inputs:
        age = st.number_input("Enter Patient Age", min_value=1, max_value=120, value=25)
        sex = st.selectbox("Biological Sex", ["Male", "Female", "Other"])
        diet = st.selectbox("Dietary Framework", ["Omnivore", "Vegetarian", "Vegan", "Keto / Low-Carb"])
        
    with col_upload:
        uploaded_pdf = st.file_uploader("Upload Lab Report PDF", type=['pdf'])
        if uploaded_pdf:
            st.success("PDF loaded successfully into cache.")
            
    if st.button("Proceed to Symptom Mapping", type="primary"):
        if not uploaded_pdf:
            st.error("Please upload a valid blood test report PDF before proceeding.")
        else:
            with st.spinner("Extracting parameters and running background anomaly pre-scan..."):
                extracted_text = extract_text_from_pdf(uploaded_pdf)
                detected_issues = run_pre_scan(extracted_text)
                
                # Update persistent data storage states
                st.session_state['report_text'] = extracted_text
                st.session_state['pre_scan_issues'] = detected_issues
                st.session_state['history'] = {"age": age, "sex": sex, "diet": diet, "pre_scan_issues": detected_issues}
                st.session_state['stage'] = 2
                st.rerun()

# ------------------------------------------
# STAGE 2: DYNAMIC SYMPTOM intake 
# ------------------------------------------
elif st.session_state['stage'] == 2:
    st.header("Step 2: Targeted Symptom Assessment")
    st.markdown("Based on an immediate pre-scan of your report text data, our AI flagged fluctuations related to: " + 
                f"**{', '.join(st.session_state['pre_scan_issues']) if st.session_state['pre_scan_issues'] else 'General Biomarkers'}**.")
    st.info("To tailor the accuracy of your final explanation report, please detail what you are physically feeling right now:")
    
    # Dynamically build a comprehensive checklist based on what anomalies were detected
    dynamic_options = []
    for issue in st.session_state['pre_scan_issues']:
        if issue in symptom_dictionary:
            dynamic_options.extend(symptom_dictionary[issue])
            
    # Add generic fallback options if nothing specific matched or was detected
    if not dynamic_options:
        dynamic_options = ["Routine Checkup", "General Fatigue", "Mild Dizziness", "Muscle Aches"]
    
    # De-duplicate options list
    dynamic_options = list(set(dynamic_options))
    
    st.subheader("Are you experiencing any of the following? (Select all that apply)")
    chosen_symptoms = []
    for symptom in dynamic_options:
        if st.checkbox(symptom):
            chosen_symptoms.append(symptom)
            
    st.subheader("Don't see your specific feeling listed? Type it manually here:")
    custom_symptom_text = st.text_area("Specify other symptoms or core health complaints:", 
                                       placeholder="e.g., I have been experiencing intense localized headaches in the afternoon and a weird metallic taste in my mouth...")
    
    col_nav = st.columns([1, 4, 1])
    with col_nav[0]:
        if st.button("⬅ Back"):
            st.session_state['stage'] = 1
            st.rerun()
    with col_nav[2]:
        if st.button("Generate Report ➡️", type="primary"):
            st.session_state['user_symptoms'] = {"checked": chosen_symptoms, "custom_text": custom_symptom_text}
            st.session_state['stage'] = 3
            st.rerun()

# ------------------------------------------
# STAGE 3: COMPREHENSIVE MEDICAL ENGINE OUTPUT
# ------------------------------------------
elif st.session_state['stage'] == 3:
    st.header("Step 3: Personalized Clinical Digest Analysis")
    
    # Global AI Medical Alert Box
    st.warning("⚠️ **AI-Assisted Analysis Disclaimer:** This system provides educational summaries using local Llama 3.2 processing pipelines. Always verify findings, data points, and suggested supplement methodologies directly with a certified medical professional before starting any treatment.")
    
    with st.spinner("Synthesizing patient data streams and mapping health metrics profiles..."):
        # Run final analysis engine calculation
        final_report = run_final_analysis(
            st.session_state['report_text'], 
            st.session_state['history'], 
            st.session_state['user_symptoms']
        )
        
        # Display heading-wise using layout containers or expanding boxes
        st.markdown("Use the structured layout sections below to explore your report parameters step-by-step:")
        
        # Parse output into clean UI sections based on headers
        sections = final_report.split("### ")
        for sec in sections:
            if sec.strip():
                lines = sec.split("\n")
                header_title = lines[0].strip()
                body_content = "\n".join(lines[1:]).strip()
                
                # Render clean expandable modules for beautiful scannability
                with st.expander(f"📌 {header_title}", expanded=True):
                    st.markdown(body_content)
                    
        st.divider()
        
        # PDF Exporter Actions
        col_actions = st.columns([1, 2, 1])
        with col_actions[0]:
            if st.button("🔄 Analyze New Document"):
                st.session_state['stage'] = 1
                st.session_state['report_text'] = ""
                st.session_state['pre_scan_issues'] = []
                st.rerun()
                
        with col_actions[2]:
            pdf_path = create_pdf_report(final_report, st.session_state['history'])
            with open(pdf_path, "rb") as pdf_file:
                st.download_button(
                    label="📥 Download Certified Summary Report (PDF)",
                    data=pdf_file,
                    file_name=f"HemoAnalyst_Report_{datetime.date.today()}.pdf",
                    mime="application/pdf"
                )
